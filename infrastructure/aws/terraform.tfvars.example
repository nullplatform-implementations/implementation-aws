###############################################################################
# AWS Provider Configuration
###############################################################################
aws_profile = "Implementations"
aws_region  = "us-east-1"

###############################################################################
# VPC Configuration
###############################################################################
organization = "nullplatform"
account      = "core"

vpc = {
  cidr_block = "10.0.0.0/16"
  azs = [
    "us-east-1a",
    "us-east-1b"
  ]
  private_subnets = [
    "10.0.1.0/24",
    "10.0.2.0/24"
  ]
  public_subnets = [
    "10.0.3.0/24",
    "10.0.4.0/24"
  ]
}

###############################################################################
# DNS Configuration
###############################################################################
dns_provider_name = "aws"
dns_type          = "external_dns"
policy            = "sync"
sources           = ["crd", "gateway-httproute"]
